    "thumbNailsExec": "/usr/bin/convert -thumbnail 200 \"%in\" \"%out\"",
    "thumbNailsRoot": "../../../thumbnails",
    "thumbNailTimeStamp": "%y_%m_%d_%H_%M_%S_",
    "thumbNailFileSuffix": ".jpg",
