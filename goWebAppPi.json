{
  "ReloadConfigSeconds": 3600,
  "Port": 8082,
  "ThumbnailTrim": [
    20,
    4
  ],
  "Exec": {
    "dmesg": {
      "StdOutType": "json",
      "Cmd": [
        "./execDmesg.sh",
        "%{find}"
      ]
    },
    "echo": {
      "StdOutType": "txt",
      "Cmd": [
        "echo",
        "User:%{user} Loc:%{loc} Find:%{find} PIUser:%{USER} PWD:%{PWD}"
      ]
    },
    "free": {
      "StdOutType": "json",
      "Cmd": [
        "./free.sh"
      ]
    },
    "ufs": {
      "Cmd": [
        "./webtools",
        "ufsConfig.json"
      ],
      "Dir": "",
      "StdOutType": "json",
      "Log": "",
      "LogOut": "",
      "LogErr": "",
      "NzCodeReturns": 200,
      "Detached": false
    }
  },
  "Users": {
    "admin": {
      "Hidden": true,
      "Name": "Admin",
      "Home": "",
      "Locations": {
        "cache": "cache",
        "logs": "logs"
      }
    },
    "julie": {
      "Hidden": null,
      "Name": "Julie",
      "Home": "***/media/USBHDD1/shares/julie",
      "Locations": {
        "thumbs": "***/home/pi/server/thumbnails/%{id}",
        "original": "***/media/USBHDD1/shares/%{id}",
        "base": ""
      }
    },
    "owain": {
      "Hidden": null,
      "Name": "Owain",
      "Home": "***/media/USBHDD1/shares/owain",
      "Locations": {
        "thumbs": "***/home/pi/server/thumbnails/%{id}",
        "original": "***/media/USBHDD1/shares/%{id}",
        "base": ""
      }
    },
    "huw": {
      "Hidden": null,
      "Name": "Huw",
      "Home": "***/media/USBHDD1/shares/huw",
      "Locations": {
        "thumbs": "***/home/pi/server/thumbnails/%{id}",
        "original": "***/media/USBHDD1/shares/%{id}",
        "base": ""
      }
    },
    "stuart": {
      "Hidden": null,
      "Name": "Stuart",
      "Home": "***/media/USBHDD1/shares/stuart",
      "Locations": {
        "dev": "Repository",
        "thumbs": "***/home/pi/server/thumbnails/%{id}",
        "original": "***/media/USBHDD1/shares/%{id}",
        "mydb": "mydb",
        "base": ""
      }
    },
    "shared": {
      "Hidden": null,
      "Name": "Shared. Somthing for everyone!",
      "Home": "***/media/USBHDD1/shares/shared",
      "Locations": {
        "thumbs": "***/home/pi/server/thumbnails/%{id}",
        "original": "***/media/USBHDD1/shares/%{id}",
        "base": ""
      }
    }
  },
  "ContentTypeCharset": "utf-8",
  "LogData": {
    "FileNameMask": "goWebServer-%y-%m-%d.log",
    "Path": "admin/logs",
    "MonitorSeconds": 30,
    "ConsoleOut": false
  },
  "ServerName": "NePiServer",
  "PanicResponseCode": 500,
  "FilterFiles": [
    ".json",
    ".data",
    ".jpeg",
    ".jpg",
    ".png",
    ".info",
    ".log"
  ],
  "ServerDataRoot": "/home/pi/server/goWebAppRoot",
  "StaticData": {
    "Path": "/home/pi/server/goWebAppRoot/static",
    "Home": "tgo.html"
  },
  "TemplateStaticFiles": {
    "Files": [
      "tgo.html",
      "tgoimage.html",
      "tgo.css"
    ],
    "DataFile": "static/templateData.json"
  },
  "FaviconIcoPath": "favicon1.ico",
  "ExecManager": {
    "Path": "./testdata/exec",
    "File": "RunningProcs.json",
    "TestCommand": "./longRunCheck.sh"
  }
}