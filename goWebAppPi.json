{
  "ReloadConfigSeconds": 3600,
  "Port": 8082,
  "ThumbnailTrim": [
    20,
    4
  ],
  "Users": {
    "admin": {
      "Hidden": true,
      "Name": "Admin",
      "Home": "",
      "Locations": {
        "cache": "cache",
        "logs" : "logs"
      },
      "Exec": {
       "dmesg": {
        "StdOutType": "json",
         "Cmd": [
             "./execDmesg.sh", "%{find}"
         ]
       },
       "echo": {
        "StdOutType": "txt",
         "Cmd": [
             "echo", "User:%{user} Loc:%{loc} Find:%{find} PIUser:%{USER} PWD:%{PWD}"
         ]
       },
       "llog": {
        "StdOutType": "txt",
         "Cmd": [
             "./latestLog.sh"
         ]
       }
      }
    },
    "stuart": {
      "Hidden": null,
      "Name": "Stuart",
      "Home": "***/media/USBHDD1/shares/stuart",
      "Locations": {
        "dev": "Repository",
        "mydb": "mydb",
        "base": ""
     }
    }
  },
  "ContentTypeCharset": "utf-8",
  "LogData": {
    "FileNameMask": "goWebServer-%y-%m-%d.log",
    "Path": "admin/logs",
    "MonitorSeconds": 30,
    "ConsoleOut": false
  },
  "ServerName": "NePiServer",
  "PanicResponseCode": 500,
  "FilterFiles": [
    ".json",
    ".data",
    ".jpeg",
    ".jpg",
    ".png",
    ".info",
    ".log"
  ],
  "ServerDataRoot": "/home/pi/server/goWebApp/testdata",
  "StaticData": {
    "Path":"/home/pi/server/goWebApp/static",
    "Home" :"dart.html"
  },
  "FaviconIcoPath": "favicon1.ico"
}
