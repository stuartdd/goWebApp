  "Users": {
    "admin": {
      "Hidden": true,
      "Name": "Admin",
      "Home": "",
      "Locations": {
        "cache": "cache",
        "logs" : "logs"
      },
      "Exec": {
       "dmesg": {
        "StdOutType": "json",
         "Cmd": [
             "./execDmesg.sh", "%{find}"
         ]
       },
       "echo": {
        "StdOutType": "txt",
         "Cmd": [
             "echo", "User:%{user} Loc:%{loc} Find:%{find} PIUser:%{USER} PWD:%{PWD}"
         ]
       },
        "ufs": {
          "Cmd": [
            "./webtools",
            "ufsConfig.json"
          ],
          "Dir": "",
          "StdOutType": "json",
          "Log": "",
          "LogOut": "",
          "LogErr": "",
          "NzCodeReturns": 200,
          "Detached": false
        }
      }
    },
    "julie": {
