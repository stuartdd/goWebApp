{
    "Prefix":"[",
    "PostFix":"]",
    "Infix":",",
    "SkipLines": 0,
    "InputFile": "cache/ufs.raw",
    "OutputFile": "cache/ufs.json",
    "MaxLines": 5,
    "Lines": [
        {
            "Split": ", ",
            "Skip": "\"",
            "MaxTokens": 2,
            "Tokens": [
                {"name":"Size", "quoted":false},
                {"name":"Name",  "quoted":true}
            ]
        }
    ]
}
