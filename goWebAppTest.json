{
    "configName": "goWebApp.json",
    "port": 8083,
    "ServerName": "TestServer",
    "filterFiles": [
        "Json",
        "Data",
        "jpeg"
    ],
    "ContentTypeCharset": "utf-8",
    "FaviconIcoPath": "favicon.ico",
    "LogData": {
        "FileNameMask": "goWebServer-%y-%m-%d-%H-%M.log",
        "Path": "logs",
        "MonitorSeconds": 30,
        "LogLevel": "quiet"
    },
    "Users": {
        "bob": {
            "name": "Bob",
            "home": "bob",
            "Locations": {
                "home": "",
                "usr": "b-testfolder",
                "pics": "b-pics"
            },
            "Exec": {
                "ls": {
                    "cmd": [
                        "ls",
                        "-lta"
                    ],
                    "dir": "",
                    "log": "logs"
                },
                "c2": {
                    "cmd": [
                        "cmd2"
                    ],
                    "dir": "",
                    "log": "logs",
                    "logOut": "logOut.txt"
                }
            }
        },
        "stuart": {
            "name": "Stuart",
            "home": "stuart",
            "Locations": {
                "home": "",
                "usr": "s-testfolder",
                "pics": "s-pics",
                "testtree": "",
                "picsPlus": "s-pics/s-testfolder",
                "picsMissing": "missingfolder"
            },
            "exec": {
                "c1": {
                    "cmd": [
                        "cmd1"
                    ],
                    "dir": "",
                    "log": "logs"
                },
                "c2": {
                    "cmd": [
                        "cmd2"
                    ],
                    "dir": "",
                    "log": "logs"
                }
            }
        }
    },
    "ServerDataRoot": "../testdata",
    "ServerStaticRoot": "../static"
}