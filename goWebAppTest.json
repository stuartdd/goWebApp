{
    "configName": "goWebApp.json",
    "port": 8083,
    "ServerName": "TestServer",
    "filterFiles": [
        "Json",
        "Data"
    ],
    "ContentTypeCharset": "utf-8",
    "FaviconIcoPath": "favicon.ico",
    "LogData": {
        "FileNameMask": "goWebServer-%y-%m-%d-%H-%M.log",
        "Path": "logs",
        "MonitorSeconds": 30,
        "LogLevel": "quiet"
    },
    "Users": {
        "bob": {
            "name": "Bob",
            "Locations": {
                "home": "",
                "usr": "logs"
            },
            "Exec": {
                "ls": {
                    "cmd": ["ls","-lta"],
                    "dir": "",
                    "log": "logs"
                },
                "c2": {
                    "cmd": ["cmd2"],
                    "dir": "",
                    "log": "logs",
                    "logOut" : "logOut.txt"
                }
            }
        },
        "stuart": {
            "name": "Stuart",
            "Locations": {
                "home": "",
                "pics": "pics",
                "picsPlus": "testfolder",
                "picsMissing": "test_folder"
            },
            "exec": {
                "c1": {
                    "cmd": ["cmd1"],
                    "dir": "",
                    "log": "logs"
                },
                "c2": {
                    "cmd": ["cmd2"],
                    "dir": "",
                    "log": "logs"
                }
            }
        }
    },
    "UserDataRoot": "../testdata"
}