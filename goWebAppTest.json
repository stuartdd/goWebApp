{
    "configName": "goWebApp.json",
    "port": 8083,
    "ServerName": "TestServer",
    "filterFiles": [
        "Json",
        "Data"
    ],
    "ContentTypeCharset": "utf-8",
    "FaviconIcoPath": "favicon1.ico",
    "LogData": {
        "FileNameMask": "goWebServer-%y-%m-%d-%H-%M.log",
        "Path": "logs",
        "MonitorSeconds": 30,
        "LogLevel": "quiet"
    },
    "Users": {
        "bob": {
            "name": "Bob",
            "Locations": {
                "home": "testdata",
                "usr": "testdata/logs"
            },
            "Exec": {
                "ls": {
                    "cmd": ["ls","-ltaz"],
                    "dir": "",
                    "log": "usr/boblog1"
                },
                "c2": {
                    "cmd": ["cmd2"],
                    "dir": "testdata",
                    "log": "home/boblog2"
                }
            }
        },
        "stuart": {
            "name": "Stuart",
            "Locations": {
                "home": "testdata",
                "pics": "testdata",
                "picsPlus": "testdata/testfolder",
                "picsMissing": "testdata/test_folder"
            },
            "exec": {
                "c1": {
                    "cmd": ["cmd1"],
                    "dir": "testdata",
                    "log": "home/stulog1"
                },
                "c2": {
                    "cmd": ["cmd2"],
                    "dir": "testdata",
                    "log": "pics/stupicslog2"
                }
            }
        }
    },
    "UserDataRoot": ".."
}