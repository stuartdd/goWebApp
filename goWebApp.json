{
    "configName": "goWebApp.json",
    "port": 8082,
    "ContentTypeCharset": "utf-8",
    "ServerName": "MyServer",
    "filterFiles": [
        "Json",
        "Data"
    ],
    "faviconIcoPath": "favicon1.ico",
    "LogData": {
        "FileNameMask": "goWebServer-%y-%m-%d.log",
        "Path": "logs",
        "MonitorSeconds": 30,
        "LogLevel": "quiet"
    },
    "Users": {
        "bob": {
            "name": "Bob",
            "Locations": {
                "home": "testdata",
                "usr": "testdata/testfolder"
            }
        },
        "stuart": {
            "name": "Stuart",
            "Exec": {
                "c1": {
                    "cmd": [
                        "ls",
                        "%{lsargs}"
                    ],
                    "dir": "***/home/stuart/git",
                    "log": "pics/logs.txt"
                }
            },
            "Locations": {
                "home": "",
                "pics": "testdata",
                "testtree": "***/home/stuart/git"
            },
            "Env": {
                "lsargs": "-l"
            }
        }
    },
    "UserDataRoot": "./"
}