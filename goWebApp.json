{
    "configName": "goWebApp.json",
    "port": 8082,
    "reloadConfigSeconds": 3600,
    "ContentTypeCharset": "utf-8",
    "ServerName": "MyServer",
    "filterFiles": [
        "Json",
        "Data",
        "jpeg",
        "jpg",
        "png"
    ],
    "faviconIcoPath": "favicon1.ico",
    "LogData": {
        "FileNameMask": "goWebServer-%y-%m-%d.log",
        "Path": "logs",
        "MonitorSeconds": 30,
        "LogLevel": "verbose"
    },
    "Users": {
        "admin": {
            "hidden": true,
            "name": "Admin",
            "home": "admin",
            "Locations": {
                "cache": "cache"
            },
            "Exec": {
                "ufs": {
                    "cmd": [
                        "./ufs.sh"
                    ],
                    "dir":"",
                    "log": "logs"
                }
            },
            "Env": {
                "lsargs": "-l"
            }
        },
        "bob": {
            "name": "Bob",
            "home": "bob",
            "Locations": {
                "home": "",
                "data": "stateData",
                "thumbs": "***%{WebServerHome}/thumbs",
                "original": "***%{WebServerHome}/original",
                "usr": "b-testfolder",
                "pics": "b-pics"
            }
        },
        "stuart": {
            "name": "Stuart",
            "home": "stuart",
            "Locations": {
                "home": "",
                "cache": "cache",
                "data": "stateData",
                "thumbs": "***%{WebServerHome}/thumbs",
                "original": "***%{WebServerHome}/original",
                "usr": "s-testfolder",
                "pics": "s-pics",
                "testtree": "***/home/stuart/git"
            },
            "Env": {
                "lsargs": "-l"
            }
        }
    },
    "ServerDataRoot": "./testdata",
    "ServerStaticRoot": "%{WebServerHome}/static",
    "TemplateStaticFiles": {
        "Files": [
            "dart.html",
            "dart.css"
        ],
        "DataFile": "configDataPI.json"
    },
    "Env": {}
}