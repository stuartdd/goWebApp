{
  "ReloadConfigSeconds": 3600,
  "Port": 8082,
  "ThumbnailTrim": [
    22,
    4
  ],
  "Exec": {
    "dmesg": {
      "StdOutType": "json",
      "Cmd": [
        "execDmesg.sh",
        "%{find}"
      ]
    },
    "free": {
      "StdOutType": "json",
      "Cmd": [
        "free.sh"
      ]
    },
    "echo": {
      "StdOutType": "txt",
      "Cmd": [
        "echo",
        "User:%{user} Find:%{find} PIUser:%{USER} PWD:%{PWD} %{year} %{month} %{dom}"
      ]
    },

    "ds": {
      "Cmd": [
        "diskSize.sh"
      ],
      "Dir": "",
      "StdOutType": "json",
      "LogDir": "",
      "LogOutFile": "",
      "LogErrFile": "",
      "NzCodeReturns": 200,
      "Detached": false
    },
    "lr1": {
      "Cmd": [
        "longRunTest1.sh"
      ],
      "Detached": true,
      "CanStop": true
    },
    "Thumbnails": {
      "Cmd": [
        "thumbnails.sh"
      ],
      "StartErrorFile": "thumbnailsError.txt",
      "Detached": true,
      "CanStop": true
    },
    "lr2": {
      "Cmd": [
        "longRunTest2.sh",
        "PASS"
      ],
      "Detached": true
    },
    "ufs": {
      "Cmd": [
        "webtools",
        "ufsConfig.json"
      ],
      "Dir": "",
      "StdOutType": "json",
      "LogDir": "",
      "LogOutFile": "",
      "LogErrFile": "",
      "NzCodeReturns": 200,
      "Detached": false
    }
  },
  "UserDataPath":"%{WebServerData}/userData.json",
  "Users": {
    "admin": {
      "Hidden": true,
      "Name": "Admin",
      "Home": "",
      "Locations": {},
      "Env": {
        "lsargs": "-l"
      }
    }
  },
  "ContentTypeCharset": "utf-8",
  "LogData": {
    "FileNameMask": "goWebServer-%y-%m-%d.log",
    "Path": "logs",
    "MonitorSeconds": 30,
    "ConsoleOut": true
  },
  "ServerName": "MyServer",
  "PanicResponseCode": 500,
  "FilterFiles": [
    ".json",
    ".data",
    ".jpeg",
    ".jpg",
    ".png",
    ".info",
    ".log"
  ],
  "ServerDataRoot": "%{WebServerData}",
  "StaticData": {
    "Path": "%{WebServerHome}/static",
    "Home": "tgo.html"
  },
  "TemplateStaticFiles": {
    "Files": [
      "tgo.html",
      "tgoimage.html",
      "tgo.css"
    ],
    "DataFile": "%{WebServerHome}/static/templateData.json"
  },
  "FaviconIcoPath": "favicon1.ico",
  "Env": {
    "linuxUserGit": "/home/stuart/git"
  },
  "ExecPath": "%{WebServerRoot}/exec"
}
