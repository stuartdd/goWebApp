{
  "ReloadConfigSeconds": 3600,
  "Port": 8082,
  "ThumbnailTrim": [
    20,
    4
  ],
  "Users": {
    "admin": {
      "Hidden": true,
      "Name": "Admin",
      "Home": "",
      "Locations": {
        "cache": "cache"
      },
      "Exec": {
        "lr1": {
          "Cmd": [
            "./longRun.sh", "../stuart/logs/longRun1_%{doy}_%{hour}_%{min}_%{sec}.log"
          ],
          "Dir": "",
          "StdOutType": "json",
          "Detached":true
        },
        "lr2": {
          "Cmd": [
            "./longRun.sh", "../stuart/logs/longRun2_%{doy}_%{hour}_%{min}_%{sec}.log"
          ],
          "Dir": "",
          "StdOutType": "json",
          "Detached":true
        },
        "ds": {
          "Cmd": [
            "./diskSize.sh"
          ],
          "Dir": "",
          "StdOutType": "json",
          "Log": "",
          "LogOut": "",
          "LogErr": "",
          "NzCodeReturns": 200
        },
        "ufs": {
          "Cmd": [
            "./textToJson",
            "ufsConfig.json"
          ],
          "Dir": "",
          "StdOutType": "json",
          "Log": "",
          "LogOut": "",
          "LogErr": "",
          "NzCodeReturns": 200
        }
      },
      "Env": {
        "lsargs": "-l"
      }
    },
    "bob": {
      "Hidden": null,
      "Name": "Bob",
      "Home": "",
      "Locations": {
        "data": "stateData",
        "home": "",
        "original": "***%{WebServerPictures}/originals/%{id}",
        "thumbs": "***%{WebServerPictures}/thumbnails/%{id}",
        "pics": "b-pics",
        "usr": "b-testfolder"
      },
      "Exec": null,
      "Env": null
    },
    "stuart": {
      "Hidden": null,
      "Name": "Stuart",
      "Home": "",
      "Locations": {
        "cache": "cache",
        "data": "stateData",
        "home": "",
        "logs": "logs",
        "pics": "s-pics",
        "testtree": "***%{WebServerPictures}",
        "original": "***%{WebServerPictures}/originals/%{id}",
        "thumbs": "***%{WebServerPictures}/thumbnails/%{id}",
        "usr": "s-testfolder"
      },
      "Exec": null,
      "Env": null
    }
  },
  "ContentTypeCharset": "utf-8",
  "LogData": {
    "FileNameMask": "goWebServer-%y-%m-%d.log",
    "Path": "admin/logs",
    "MonitorSeconds": 30,
    "LogLevel": "verbose",
    "ConsoleOut": true
  },
  "ServerName": "MyServer",
  "PanicResponseCode": 500,
  "FilterFiles": [
    ".json",
    ".data",
    ".jpeg",
    ".jpg",
    ".png",
    ".log"
  ],
  "ServerDataRoot": "./testdata",
  "ServerStaticRoot": "%{WebServerHome}/static",
  "TemplateStaticFiles": {
    "Files": [
      "dart.html",
      "dart.css"
    ],
    "DataFile": "./testdata/configDataPI.json",
    "Data": null,
    "FullFileName": ""
  },
  "FaviconIcoPath": "favicon1.ico",
  "Env": {
    "linuxUserGit": "/home/stuart/git"
  },
  "ExecManager":{
    "Path" : "./testdata/admin",
    "File" : "RunningProcs.json",
    "TestCommand" : "./checkLrp.sh"
  }
}