{
    "port": 8082,
    "reloadConfigSeconds": 3600,
    "ContentTypeCharset": "utf-8",
    "ServerName": "MyServer",
    "ThumbNailTrim": [
        20,
        4
    ],
    "filterFiles": [
        "Json",
        "Data",
        "jpeg",
        "jpg",
        "png",
        "log"
    ],
    "faviconIcoPath": "favicon1.ico",
    "LogData": {
        "FileNameMask": "goWebServer-%y-%m-%d.log",
        "Path": "admin/logs",
        "MonitorSeconds": 30,
        "LogLevel": "verbose"
    },
    "Users": {
        "admin": {
            "hidden": true,
            "name": "Admin",
            "home": "",
            "Locations": {
                "cache": "cache"
            },
            "Exec": {
                "ufs": {
                    "cmd": [
                        "./textToJson",
                        "ufsConfig.json"
                    ],
                    "nzCodeReturns": 200,
                    "stdOutType": "json"
                },
                "ds": {
                    "cmd": [
                        "./diskSize.sh"
                    ],
                    "nzCodeReturns": 200,
                    "stdOutType": "json"
                },
                "restart": {
                    "cmd": [
                        "./restartServer.sh"
                    ],
                    "log": "logs",
                    "LogOut": "restartOut_%{year}_%{month}_%{day}_%{hour}_%{min}_%{sec}.txt",
                    "LogErr": "restartErr_%{year}_%{month}_%{day}_%{hour}_%{min}_%{sec}.txt"
                }
            },
            "Env": {
                "lsargs": "-l"
            }
        },
        "bob": {
            "name": "Bob",
            "home": "",
            "Locations": {
                "home": "",
                "data": "stateData",
                "thumbs": "***/home/stuart/git/thumbnails/%{id}",
                "original": "***%{WebServerHome}/original",
                "usr": "b-testfolder",
                "pics": "b-pics"
            }
        },
        "stuart": {
            "name": "Stuart",
            "home": "",
            "Locations": {
                "home": "",
                "cache": "cache",
                "logs": "logs",
                "data": "stateData",
                "thumbs": "***%{linuxUserGit}/thumbnails/%{id}",
                "original": "***%{linuxUserGit}/originals/%{id}",
                "usr": "s-testfolder",
                "pics": "s-pics",
                "testtree": "***%{linuxUserGit}"
            }
        }
    },
    "ServerDataRoot": "./testdata",
    "ServerStaticRoot": "%{WebServerHome}/static",
    "TemplateStaticFiles": {
        "Files": [
            "dart.html",
            "dart.css"
        ],
        "DataFile": "configDataPI.json"
    },
    "Env": {
        "linuxUserGit": "/home/stuart/git"
    }
}