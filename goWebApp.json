{
  "ReloadConfigSeconds": 3600,
  "Port": 8082,
  "ThumbnailTrim": [
    20,
    4
  ],
  "Users": {
    "admin": {
      "Hidden": true,
      "Name": "Admin",
      "Home": "",
      "Locations": {
        "cache": "cache"
      },
      "Exec": {
        "ds": {
          "Cmd": [
            "./diskSize.sh"
          ],
          "Dir": "",
          "StdOutType": "json",
          "Log": "",
          "LogOut": "",
          "LogErr": "",
          "NzCodeReturns": 200
        },
        "restart": {
          "Cmd": [
            "./restartServer.sh"
          ],
          "Dir": "",
          "StdOutType": "",
          "Log": "logs",
          "LogOut": "restartOut_%{year}_%{month}_%{day}_%{hour}_%{min}_%{sec}.txt",
          "LogErr": "restartErr_%{year}_%{month}_%{day}_%{hour}_%{min}_%{sec}.txt",
          "NzCodeReturns": 0
        },
        "ufs": {
          "Cmd": [
            "./textToJson",
            "ufsConfig.json"
          ],
          "Dir": "",
          "StdOutType": "json",
          "Log": "",
          "LogOut": "",
          "LogErr": "",
          "NzCodeReturns": 200
        }
      },
      "Env": {
        "lsargs": "-l"
      }
    },
    "bob": {
      "Hidden": null,
      "Name": "Bob",
      "Home": "",
      "Locations": {
        "data": "stateData",
        "home": "",
        "original": "***%{WebServerHome}/original",
        "pics": "b-pics",
        "thumbs": "***/home/stuart/git/thumbnails/%{id}",
        "usr": "b-testfolder"
      },
      "Exec": null,
      "Env": null
    },
    "stuart": {
      "Hidden": null,
      "Name": "Stuart",
      "Home": "",
      "Locations": {
        "cache": "cache",
        "data": "stateData",
        "home": "",
        "logs": "logs",
        "original": "***%{linuxUserGit}/originals/%{id}",
        "pics": "s-pics",
        "testtree": "***%{linuxUserGit}",
        "thumbs": "***%{linuxUserGit}/thumbnails/%{id}",
        "usr": "s-testfolder"
      },
      "Exec": null,
      "Env": null
    }
  },
  "ContentTypeCharset": "utf-8",
  "LogData": {
    "FileNameMask": "goWebServer-%y-%m-%d.log",
    "Path": "admin/logs",
    "MonitorSeconds": 30,
    "LogLevel": "verbose",
    "ConsoleOut" : true
  },
  "ServerName": "MyServer",
  "PanicResponseCode": 500,
  "FilterFiles": [
    "..json",
    "..data",
    "..jpeg",
    "..jpg",
    "..png",
    "..log"
  ],
  "ServerDataRoot": "./testdata",
  "ServerStaticRoot": "%{WebServerHome}/static",
  "TemplateStaticFiles": {
    "Files": [
      "dart.html",
      "dart.css"
    ],
    "DataFile": "configDataPI.json",
    "Data": null,
    "FullFileName": ""
  },
  "FaviconIcoPath": "favicon1.ico",
  "Env": {
    "linuxUserGit": "/home/stuart/git"
  }
}
